        "react-select": "5.10.2",
        "react-window": "2.2.7"
    },
    "devDependencies": {
        "@eslint/js": "9.39.5",
        "@playwright/test": "1.61.1",
        "@types/isomorphic-fetch": "0.0.39",
        "@types/node": "24.13.3",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
