        "webpack-dev-server": "6.0.0"
    },
    "scripts": {
        "start": "NODE_ENV=development npx webpack serve --mode development",
        "build": "GENERATE_SOURCEMAP=false NODE_ENV=production npx webpack --mode production",
        "lint": "eslint -c eslint.config.mjs",
        "test": "concurrently -s first -k 'npm:mock-api' 'playwright test'",
        "mock-api": "npm --prefix mock-api run mock-api",
        "ci:install-deps": "playwright install-deps && npm --prefix mock-api ci",
        "ci:chromium": "playwright install chromium"
    },
    "browserslist": [
        "last 1 version",
        "> 1%",
        "not dead"
    ],
    "engines": {
        "node": "^24"
    }
